APP_NAME=Pookal
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://YOUR_RENDER_SERVICE.onrender.com

# Render sets DATABASE_URL automatically when you add a PostgreSQL database
DATABASE_URL=
DB_CONNECTION=pgsql

# Manually set these if not using DATABASE_URL:
# DB_HOST=
# DB_PORT=5432
# DB_DATABASE=pookal
# DB_USERNAME=
# DB_PASSWORD=
# DB_SSLMODE=require

# Your Vercel frontend URL (no trailing slash)
FRONTEND_URL=https://YOUR_APP.vercel.app
FRONTEND_URLS=https://YOUR_APP.vercel.app

SANCTUM_STATEFUL_DOMAINS=YOUR_APP.vercel.app

CACHE_STORE=file
QUEUE_CONNECTION=database
SESSION_DRIVER=file
