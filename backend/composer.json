{
  "name": "pookal/backend",
  "type": "project",
  "description": "Pookal florist platform Laravel API skeleton.",
  "require": {
    "php": "^8.2",
    "laravel/framework": "^12.0",
    "laravel/sanctum": "^4.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "@php artisan package:discover --ansi"
    ],
    "serve": [
      "@php -S localhost:8000 -t public"
    ]
  }
}
